<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Include Spring Boot's default logback configuration -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- ========== Appenders ========== -->

    <!-- Console Appender: human-readable with correlation ID (dev/test/default) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%X{correlationId:-}] [user:%X{userId:-}] %-5level
                %logger{36} - %msg%n
            </pattern>
        </encoder>
    </appender>

    <!-- JSON Console Appender: structured JSON for Docker log driver / Loki (prod) -->
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>correlationId</includeMdcKeyName>
            <includeMdcKeyName>userId</includeMdcKeyName>
            <includeMdcKeyName>username</includeMdcKeyName>
        </encoder>
    </appender>

    <!-- ========== DEV Profile Configuration ========== -->
    <springProfile name="dev">
        <!-- Development: Detailed console logging, no file logging -->
        <logger name="com.wellkorea.backend" level="DEBUG"/>
        <logger name="org.springframework.security" level="DEBUG"/>
        <logger name="org.hibernate.SQL" level="DEBUG"/>
        <logger name="org.hibernate.type.descriptor.sql.BasicBinder" level="TRACE"/>
        <logger name="org.springframework.web" level="DEBUG"/>

        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE"/>
        </root>
    </springProfile>

    <!-- ========== TEST Profile Configuration ========== -->
    <springProfile name="test">
        <!-- Test: Minimal logging to reduce test output noise -->
        <logger name="com.wellkorea.backend" level="INFO"/>
        <logger name="org.springframework.security" level="WARN"/>
        <logger name="org.hibernate.SQL" level="WARN"/>
        <logger name="org.testcontainers" level="INFO"/>

        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- ========== PROD Profile Configuration ========== -->
    <springProfile name="prod">
        <!-- Production: JSON structured logging for Loki/Promtail ingestion
             Logs go to stdout only - Promtail captures via Docker socket -->
        <logger name="com.wellkorea.backend" level="INFO"/>
        <logger name="org.springframework.security" level="WARN"/>
        <logger name="org.hibernate.SQL" level="WARN"/>
        <logger name="org.springframework.web" level="WARN"/>

        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE"/>
        </root>
    </springProfile>

    <!-- ========== Default (no profile) Configuration ========== -->
    <springProfile name="!dev &amp; !test &amp; !prod">
        <!-- Default: INFO level console logging -->
        <logger name="com.wellkorea.backend" level="INFO"/>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

</configuration>
