      },
      {
        "current": { "selected": false, "text": "Loki", "value": "Loki" },
        "hide": 0,
        "includeAll": false,
        "label": "Loki",
        "multi": false,
        "name": "loki_datasource",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Seoul",
  "title": "WellKorea ERP - JVM & HTTP Metrics",
  "uid": "wellkorea-erp-jvm",
  "version": 1
}
