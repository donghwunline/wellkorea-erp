{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "HTTP Requests",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "req/s",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "mode": "none" }
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{application=\"wellkorea-erp-backend\"}[5m])",
          "legendFormat": "{{method}} {{uri}} [{{status}}]"
        }
      ],
      "title": "HTTP Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "seconds",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "mode": "none" }
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{application=\"wellkorea-erp-backend\"}[5m]))",
          "legendFormat": "p99 {{method}} {{uri}}"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{application=\"wellkorea-erp-backend\"}[5m]))",
          "legendFormat": "p95 {{method}} {{uri}}"
        }
      ],
      "title": "HTTP Response Latency (p95 / p99)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "errors/s",
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "mode": "none" }
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{application=\"wellkorea-erp-backend\", status=~\"5..\"}[5m])",
          "legendFormat": "5xx {{method}} {{uri}}"
        },
        {
          "expr": "rate(http_server_requests_seconds_count{application=\"wellkorea-erp-backend\", status=~\"4..\"}[5m])",
          "legendFormat": "4xx {{method}} {{uri}}"
        }
      ],
      "title": "HTTP Error Rate (4xx / 5xx)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "JVM Memory",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "mode": "none" }
          },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 4,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"wellkorea-erp-backend\", area=\"heap\"}",
          "legendFormat": "Used: {{id}}"
        },
        {
          "expr": "jvm_memory_committed_bytes{application=\"wellkorea-erp-backend\", area=\"heap\"}",
          "legendFormat": "Committed: {{id}}"
        },
        {
          "expr": "jvm_memory_max_bytes{application=\"wellkorea-erp-backend\", area=\"heap\"}",
          "legendFormat": "Max: {{id}}"
        }
      ],
      "title": "JVM Heap Memory",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "mode": "none" }
          },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 5,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"wellkorea-erp-backend\", area=\"nonheap\"}",
          "legendFormat": "Used: {{id}}"
        },
        {
          "expr": "jvm_memory_committed_bytes{application=\"wellkorea-erp-backend\", area=\"nonheap\"}",
          "legendFormat": "Committed: {{id}}"
        }
      ],
      "title": "JVM Non-Heap Memory",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "JVM Threads & GC",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "mode": "none" }
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 6,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"wellkorea-erp-backend\"}",
          "legendFormat": "Live"
        },
        {
          "expr": "jvm_threads_daemon_threads{application=\"wellkorea-erp-backend\"}",
          "legendFormat": "Daemon"
        },
        {
          "expr": "jvm_threads_peak_threads{application=\"wellkorea-erp-backend\"}",
          "legendFormat": "Peak"
        }
      ],
      "title": "JVM Threads",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "mode": "none" }
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 7,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{application=\"wellkorea-erp-backend\"}[5m])",
          "legendFormat": "GC Pause: {{action}} ({{cause}})"
        }
      ],
      "title": "GC Pause Duration",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 103,
      "title": "Logs (Loki)",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 28 },
      "id": 8,
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{service=\"backend\"} |= ``",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Backend Logs",
      "type": "logs"
    }
  ],
  "schemaVersion": 39,
  "tags": ["wellkorea-erp", "jvm", "spring-boot"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Prometheus",
        "multi": false,
        "name": "datasource",
        "options": [],
